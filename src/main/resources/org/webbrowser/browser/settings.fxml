<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<FlowPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.webbrowser.settings.SettingsController">
   <children>
      <GridPane prefHeight="91.0" prefWidth="399.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Default Engine:" />
            <ComboBox fx:id="defaultBrowserSelectionBox" prefWidth="150.0" GridPane.columnIndex="1" />
             <FlowPane GridPane.rowIndex="2">
                 <Button mnemonicParsing="false" onAction="#saveChanges" text="Save Changes" />
               <Button mnemonicParsing="false" onAction="#resetChanges" text="Default" />

             </FlowPane>
         </children>
      </GridPane>
   </children>
</FlowPane>
