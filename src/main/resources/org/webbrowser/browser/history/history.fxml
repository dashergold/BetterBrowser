<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.webbrowser.browser.controller.HistoryController">

   <top>
      <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 8;">
         <Button fx:id="clearHistoryButton" text="Clear browser history" onAction="#deleteHistory" />
      </HBox>
   </top>

   <center>
      <TableView fx:id="historyTable"
                 style="-fx-background-color: transparent;">
         <columns>
            <TableColumn fx:id="dateCol" text="Date" prefWidth="180" />
            <TableColumn fx:id="urlCol" text="URL" prefWidth="400" />
         </columns>
      </TableView>
   </center>
</BorderPane>