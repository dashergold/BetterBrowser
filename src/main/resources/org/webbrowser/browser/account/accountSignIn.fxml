<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.webbrowser.accounts.controller.SignInController">
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <children>
            <FlowPane alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="200.0">
               <children>
                  <Label text="Login" />
               </children>
            </FlowPane>
            <FlowPane prefHeight="200.0" prefWidth="200.0">
               <children>
                  <Label text="Email:" />
                  <TextField fx:id="emailField" promptText="Email" />
               </children>
            </FlowPane>
            <FlowPane prefHeight="200.0" prefWidth="200.0">
               <children>
                  <Label text="Password:" />
                  <PasswordField fx:id="passwordField" promptText="Password" />
               </children>
            </FlowPane>
            <FlowPane prefHeight="200.0" prefWidth="200.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleLogin" text="Sign in" />
                  <Label text="Don't have an account?" />
                  <Hyperlink onAction="#goToRegister" text="Register" />
               </children>
            </FlowPane>
            <Label text="" fx:id="errorLabel" styleClass="warningLabel"/>
         </children>
      </VBox>
   </center>
</BorderPane>
