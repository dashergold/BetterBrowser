<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<FlowPane fx:id="settingsWindow" alignment="TOP_RIGHT" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.webbrowser.settings.controller.SettingsController">
   <children>
       <VBox alignment="TOP_RIGHT">
           <Button alignment="TOP_RIGHT" contentDisplay="RIGHT" mnemonicParsing="false" onAction="#closeSettings" styleClass="closeButton" text="Close" StackPane.alignment="TOP_RIGHT" />
       </VBox>
       <VBox spacing="10"  styleClass="sideContent">

          <GridPane vgap="30" prefHeight="91.0" prefWidth="399.0">
            <columnConstraints>
              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
             <children>
                <Label text="Default Engine:" />
                <ComboBox fx:id="defaultBrowserSelectionBox" prefWidth="150.0" GridPane.columnIndex="1" />
                 <FlowPane GridPane.rowIndex="2">
                     <Button mnemonicParsing="false" onAction="#saveChanges" text="Save Changes" />


                 </FlowPane>
                <FlowPane hgap="10" alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="1" fx:id="accountSettingsInfo">
                   <children>
                      <Label fx:id="currentAcc" text="test" />
                      <Button mnemonicParsing="false" onAction="#openAccountWindow" text="Account settings" />
                   </children>
                </FlowPane>
                <Label text="Account:" GridPane.rowIndex="1" />
             </children>
          </GridPane>
       </VBox>
   </children>
</FlowPane>
